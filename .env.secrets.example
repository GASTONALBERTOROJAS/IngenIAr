# IngenIAr — Secrets Configuration
# ==================================
#
# This file is a TEMPLATE. Copy it to .env.secrets and fill in your real values.
#
#   cp .env.secrets.example .env.secrets
#   python scripts/setup_secrets.py
#
# .env.secrets is gitignored — your real secrets will never be committed.
# After editing, run `python scripts/setup_secrets.py` to inject them into opencode.json.
#
# NEVER commit .env.secrets to the repository.

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://postgres:yourpassword@localhost:5432/postgres
POSTGRES_CONNECTION_STRING=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Brave Search API key (optional)
# Get one at: https://brave.com/search/api/
BRAVE_API_KEY=
